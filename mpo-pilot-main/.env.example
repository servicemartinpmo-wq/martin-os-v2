# Copy to `.env` and fill in values. Do not commit `.env`.
# Client (Vite) — from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Miiddle micro-frontend (optional PMO-Ops integration)
# VITE_ENABLE_MIIDDLE=true   # show Miiddle in sidebar (route /miiddle/* is always registered)
# VITE_MIIDDLE_BASE_URL=http://localhost:5010   # fallback when service-status is unavailable
# MIIDDLE_BASE_URL=         # server-side; defaults to VITE_MIIDDLE_BASE_URL or localhost:5010

# Server-only (never expose in frontend or commit real values)
# SUPABASE_URL=          # optional; defaults to VITE_SUPABASE_URL if unset
# SUPABASE_SERVICE_ROLE_KEY=
