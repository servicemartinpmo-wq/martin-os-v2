# Copy to `.env` and fill in values. Do not commit `.env`.
# Client (Vite) — from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Miiddle micro-frontend (PMO-Ops add-on — same pattern as Tech-Ops; route /miiddle/* is always registered)
# VITE_MIIDDLE_BASE_URL=http://localhost:5010   # client: iframe fallback when status API is unsure
# MIIDDLE_BASE_URL=http://localhost:5010        # server: /api/miiddle/service-status & health target

# Vite dev server (default 5001 in vite.config.ts — avoids macOS port 5000 conflicts)
# VITE_PORT=5001
# Optional: listen on all interfaces (default 127.0.0.1)
# VITE_DEV_HOST=0.0.0.0
#
# Express API port (default 3001) — must match Vite’s /api proxy in dev unless you override both:
# PORT=3001
# VITE_DEV_API_ORIGIN=http://127.0.0.1:3001

# Postgres + session — required for Replit OIDC / passport sessions (server boot will skip auth without these)
# Local Supabase CLI: run `supabase start` in this folder, then copy the DB URL from `supabase status`.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# SESSION_SECRET=replace-with-a-long-random-string-in-production

# Tech-Ops iframe / proxy (optional overrides)
# VITE_TECH_OPS_BASE_URL=https://tech-ops.replit.app   # client: iframe when status API is unsure
# TECH_OPS_BASE_URL=https://tech-ops.replit.app        # server: /api/techops/service-status target

# Pexels — server-only. Used by GET /api/pexels/search and /api/pexels/curated (proxied from the Express app).
# Dashboard/onboarding heroes use static Pexels CDN URLs and do not require this key.
# https://www.pexels.com/api/
# PEXELS_API_KEY=

# Server-only (never expose in frontend or commit real values)
# SUPABASE_URL=          # optional; defaults to VITE_SUPABASE_URL if unset
# SUPABASE_SERVICE_ROLE_KEY=
