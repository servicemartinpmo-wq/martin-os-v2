{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*", "app/*"],
      "@brain": ["brain/index.ts"],
      "@brain/*": ["brain/*"]
    },
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "strictNullChecks": true,
    "ignoreDeprecations": ["6.0"]
  }
}