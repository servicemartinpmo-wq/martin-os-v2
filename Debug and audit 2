// Path: /apps/pmo-ops/lib/engine/maturity-calculator.ts

interface InitiativeData {
  sopAdherence: number; // 0-1
  deadlineMet: boolean;
  resourceLoad: number; // 0-1
}

/**
 * Calculates Maturity Score (0-100) based on forensic data
 */
export const calculateOperationalStatus = (initiatives: InitiativeData[]) => {
  if (initiatives.length === 0) return 0;

  const weights = {
    sop: 0.4,
    velocity: 0.4,
    capacity: 0.2
  };

  const avgSop = initiatives.reduce((acc, i) => acc + i.sopAdherence, 0) / initiatives.length;
  const velocity = initiatives.filter(i => i.deadlineMet).length / initiatives.length;
  const loadFactor = 1 - (initiatives.reduce((acc, i) => acc + i.resourceLoad, 0) / initiatives.length);

  const score = (avgSop * weights.sop) + (velocity * weights.velocity) + (loadFactor * weights.capacity);
  
  return Math.round(score * 100);
};
