# Martin OS — copy to `.env.local` (never commit real keys)
#
# Local dev: `npm run dev` → http://localhost:3000 (keep terminal open)
#
# VPS (Node): copy to `.env.production` on the server, then `npm run vps:deploy`
# VPS (Docker): copy these keys into a root `.env` file for docker-compose build args, then `npm run docker:up`

# Optional: Pexels API for Miidle carousel / remote media (falls back to curated static assets if unset)
# NEXT_PUBLIC_PEXELS_API_KEY=

# Supabase — live PMO/Tech data (optional; demo data if unset)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
