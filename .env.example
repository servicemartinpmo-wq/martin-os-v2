# Martin OS — copy to `.env.local` (never commit real keys)
#
# Local dev uses a single stack: `npm run dev` → http://127.0.0.1:3000 (see package.json scripts).

# Optional: Pexels API for Miidle carousel / remote media (falls back to curated static assets if unset)
# NEXT_PUBLIC_PEXELS_API_KEY=

# Supabase (used by extended routes / features when configured)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
